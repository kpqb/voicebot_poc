# LiveKit Cloud credentials (must match agent/.env)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# OpenAI Realtime API — required for voice chat (server-side only)
OPENAI_API_KEY=

# Demo login (change in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Session signing secret — set a long random string in production
AUTH_SECRET=
