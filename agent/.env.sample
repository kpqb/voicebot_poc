# Sign Up for LiveKit Cloud --> https://cloud.livekit.io
# Copy this file to .env and fill in the values. It should match ../web/.env.local
LIVEKIT_URL=<livekit-url>
LIVEKIT_API_KEY=<livekit-api-key>
LIVEKIT_API_SECRET=<livekit-api-secret>

# OpenAI key for the Realtime API (required for the simple chat UI)
OPENAI_API_KEY=<openai-api-key>

# System prompt file (default: ../prompts/prompt.txt)
# PROMPT_FILE=../prompts/prompt2.txt
